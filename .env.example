# Copy to .env and source it (or set in systemd) in production.
PEPTIDENET_SECRET_KEY=change-me-to-a-long-random-string
PEPTIDENET_DEBUG=0

# ALLOWED_HOSTS — generate with: python manage.py emit_hosts
PEPTIDENET_HOSTS=smashfatbiolabs.ca,www.smashfatbiolabs.ca,smashfatbiolabs.com

# CSRF trusted origins (https://domain,...) — usually the same domains with scheme.
PEPTIDENET_CSRF_ORIGINS=https://smashfatbiolabs.ca,https://smashfatbiolabs.com

# Managed Postgres (leave DB_HOST empty to use local SQLite in dev)
PEPTIDENET_DB_HOST=
PEPTIDENET_DB_NAME=peptidenet
PEPTIDENET_DB_USER=doadmin
PEPTIDENET_DB_PASSWORD=
PEPTIDENET_DB_PORT=25060
PEPTIDENET_DB_SSLMODE=require

# Flip to 1 only after a real payment processor is wired in apps/orders/payments.py
PEPTIDENET_PAYMENTS_LIVE=0

# --- Email (Mailgun) ---
# Leave MAIL_LIVE=0 to log every email to the portal without sending. Flip to 1
# only after adding a verified BioLabs sending domain (e.g. mg.smashfatbiolabs.ca)
# and pasting the key below. US region base URL shown; use api.eu.mailgun.net for EU.
PEPTIDENET_MAIL_LIVE=0
MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.smashfatbiolabs.ca
MAILGUN_BASE_URL=https://api.mailgun.net/v3
PEPTIDENET_DEFAULT_FROM=SmashFat BioLabs <no-reply@smashfatbiolabs.ca>
PEPTIDENET_REPLY_TO=
PEPTIDENET_ALERTS_TO=jeff@smashscrap.com
PEPTIDENET_PORTAL_URL=https://smashfatbiolabs.ca
